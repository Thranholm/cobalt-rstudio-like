  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#0088FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": ["string", 
                "string.quoted", 
                "string.regexp",
                "constant.character.escape",
                "punctuation.definition.string.begin.yaml", 
                "punctuation.definition.string.end.yaml"
              ],
      "settings": {
        "foreground": "#3AD900"
      }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "keyword.other"],
      "settings": {
        "foreground": "#FF9D00"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#BED6FF"
      }
    },
    {
      "name": "Meta",
      "scope": ["meta.bracket"],
      "settings": {
        "foreground": "#BED6FF"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.character",
        "constant.other",
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#FF628C"
      }
    },
    {
      "name": "Support",
      "scope": ["support"],
      "settings": {
        "foreground": "#80FFBB"
      }
    },
    {
      "name": "Support Constant",
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#EB939A"
      }
    },
    {
      "name": "Support Function",
      "scope": ["support.function"],
      "settings": {
        "foreground": "#FFB054"
      }
    },
    {
      "name": "Storage",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#FFEE80"
      }
    },
    {
      "name": "Entity",
      "scope": [
        "entity",
        "entity.name",
        "entity.name.function",
        "entity.name.class",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "name": "Type",
      "scope": ["support.type"],
      "settings": {
        "foreground": "#FFEE80"
      }
    },
    {
      "name": "Entity Tag",
      "scope": ["entity.name.tag", "meta.tag"],
      "settings": {
        "foreground": "#9EFFFF"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Variable Language",
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#FF80E1"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": {
        "foreground": "#F8F8F8"
      }
    },
    {
      "name": "Markup Heading",
      "scope": ["markup.heading", "entity.name.section", "punctuation.definition.heading.quarto"],
      "settings": {
        "foreground": "#C8E4FD"
      }
    },
    {
      "name": "Markup List",
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#CCCCCC"
      }
    },
    {
      "name": "Markup Bold",
      "scope": ["markup.bold", "punctuation.definition.bold.quarto"],
      "settings": {
        "foreground": "#FF628C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Italic",
      "scope": ["markup.italic", "punctuation.definition.italic.quarto"],
      "settings": {
        "foreground": "#FF628C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup Inline Code",
      "scope": ["markup.inline.raw", "markup.raw", 	"punctuation.definition.raw.quarto"],
      "settings": {
        "foreground": "#FF9D00"
      }
    },
    {
      "name": "Markup Link",
      "scope": ["markup.underline.link", "meta.link"],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Markup Link text",
      "scope": "string.other.link.title.quarto",
      "settings": {
        "foreground": "#FF9D00"
      }
    },
    {
      "name": "Quarto fenced code block",
      "scope": "markup.fenced_code.block.markdown",
      "settings": {
        "foreground": "#FF9D00"
      }
    },
    {
      "name": "Quarto punctuation code block",
      "scope": "punctuation.definition.markdown",
      "settings": {
        "foreground": "#FF9D00"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Function Call",
      "scope": [
        "meta.function-call",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#FF9D00"
      }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#9EFFFF"
      }
    },
    {
      "name": "CSS Value",
      "scope": ["support.constant.property-value.css"],
      "settings": {
        "foreground": "#3AD900"
      }
    },
    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#9EFFFF"
      }
    },
    {
      "name": "YAML strings",
      "scope": ["string.unquoted.plain.out.yaml"],
      "settings": {
        "foreground": "#FFFFFF"
      }
    }
  ]
}